# PrepAI Platform Backend Environment Configurations

# 1. Server Configuration
PORT=3000
NODE_ENV=development

# 2. Database Connection (Prisma ORM & PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres_secure_pass_999@localhost:5432/prepai?schema=public"

# 3. Redis Configuration (BullMQ & Cache engine)
REDIS_URL="redis://localhost:6379"

# 4. Authentication Secrets
JWT_SECRET="prepai_production_ready_jwt_secret_token_key_999!"
JWT_REFRESH_SECRET="prepai_production_ready_refresh_secret_999!"

# 5. Third Party AI Keys & OAuth
GEMINI_API_KEY=""
LINKEDIN_CLIENT_ID=""
LINKEDIN_CLIENT_SECRET=""

# 6. Cloudinary (Optional, for avatar and resume files uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
